{
  "name": "forgeplan",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first production plant modeling and optimization platform.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "dev": "vite",
    "dev:local-solver": "VITE_FORGEPLAN_ENABLE_LOCAL_CP_SAT=1 vite",
    "preview": "vite preview",
    "solve": "node scripts/forgeplan-solve.mjs",
    "server": "npm run build && node scripts/forgeplan-server.mjs",
    "solver:bootstrap": "python3 -m venv .venv && .venv/bin/python -m pip install --upgrade pip && .venv/bin/python -m pip install -r requirements-solver.txt",
    "solver:check": "${FORGEPLAN_PYTHON_BINARY:-.venv/bin/python} -c \"import ortools; print(ortools.__version__)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "jsdom": "^29.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
