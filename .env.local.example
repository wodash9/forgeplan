# ForgePlan local solver profile
# Copy to .env.local only for trusted local/private development.

VITE_FORGEPLAN_ENABLE_LOCAL_CP_SAT=1
VITE_FORGEPLAN_API_BASE_URL=http://127.0.0.1:8787
FORGEPLAN_PYTHON_BINARY=.venv/bin/python
FORGEPLAN_PORT=8787
FORGEPLAN_HOST=127.0.0.1

# ForgePlan platform / Keycloak profile
# VITE_* values are public and are baked into the browser bundle. Do not put secrets here.
VITE_AUTH_MODE=keycloak
VITE_KEYCLOAK_URL=https://auth.etharlia.com
VITE_KEYCLOAK_REALM=etharlia
VITE_KEYCLOAK_CLIENT_ID=forgeplan-spa
VITE_KEYCLOAK_ROLE_CLIENT_ID=forgeplan-spa
VITE_FORGEPLAN_USER_ADMIN_API_BASE_URL=

# Server-only Keycloak Admin API values. Set in Coolify/runtime env, never in frontend.
FORGEPLAN_KEYCLOAK_URL=https://auth.etharlia.com
FORGEPLAN_KEYCLOAK_REALM=etharlia
FORGEPLAN_KEYCLOAK_ADMIN_CLIENT_ID=forgeplan-admin-api
FORGEPLAN_KEYCLOAK_ADMIN_CLIENT_SECRET=replace-with-server-only-secret
FORGEPLAN_KEYCLOAK_ROLE_CLIENT_ID=forgeplan-spa
FORGEPLAN_ADMIN_ROLES=forgeplan-admin
FORGEPLAN_API_ACCESS_MODE=keycloak
FORGEPLAN_CORS_ALLOW_ORIGIN=http://127.0.0.1:5173
# CP-SAT is disabled unless explicitly enabled on a trusted/private runtime.
FORGEPLAN_CP_SAT_ENABLED=0
